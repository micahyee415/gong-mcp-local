# Gong API credentials — dedicated admin key, do NOT share with a production MCP server
GONG_ACCESS_KEY=
GONG_ACCESS_KEY_SECRET=
GONG_BASE_URL=https://your-org.api.gong.io
GONG_USER_EMAIL=user@example.com

# Parallelism for fan-out tools (keep at 3 to respect Gong's 3 req/sec ceiling)
MAX_CONCURRENCY=3
